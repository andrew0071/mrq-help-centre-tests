{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Registration Test",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/@cucumber/cucumber/bin/cucumber-js",
            "args": [
                "--tags",
                "@registration"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env",
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ]
}