{
  "name": "mrq-help-centre-tests",
  "version": "1.0.0",
  "description": "MrQ Help Centre Playwright + Cucumber tests",
  "type": "commonjs",
  "scripts": {
     "test": "cucumber-js --format pretty",
    "test:smoke": "cucumber-js --tags \"@smoke\"",
    "test:headed": "cross-env HEADLESS=false cucumber-js",
    "test:headless": "cross-env HEADLESS=true cucumber-js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.2.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.61.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}